# ===========================================================================
# Transworld PeopleOps Portal — environment
# ===========================================================================
# Supabase Postgres via the TRANSACTION POOLER (IPv4-friendly, Vercel-ready).
# Replace YOUR_PASSWORD with your Supabase database password.
#  - If the password contains symbols (@ : / ? # &), percent-encode them
#    (e.g. @ -> %40), OR use a URL-safe generated password.
#  - Keep the ?pgbouncer=true at the end (required for the pooler + Prisma).
DATABASE_URL="postgresql://postgres.qvqupbzgzyohtrswqqon:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# OPTIONAL — only if you later run Prisma-managed migrations (npx prisma migrate).
# The database schema was applied via SQL directly in Supabase, so this is NOT
# needed for the app to run. Uses the session/direct connection (port 5432).
# DIRECT_URL="postgresql://postgres.qvqupbzgzyohtrswqqon:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# ---------------------------------------------------------------------------
# AUTH (added in v0.2.0)
# ---------------------------------------------------------------------------
# Secret used to sign session cookies. Use a long random string.
# Generate one with:  openssl rand -hex 32
# This MUST also be set in the Vercel project environment, or production
# sign-in will fail.
SESSION_SECRET="replace-with-a-long-random-string"

# One-time admin bootstrap (used only by `npm run auth:bootstrap`, run locally).
# Not needed by the running app or on Vercel. Use a strong password and rotate
# it after first sign-in.
ADMIN_EMAIL="okezie.ofoegbu@transworld.com.ng"
ADMIN_NAME="Okezie Ofoegbu"
ADMIN_PASSWORD="replace-with-a-strong-temporary-password"

NODE_ENV="development"
