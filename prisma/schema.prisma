// TW-GOAL-AGREEMENT-MODELS-V0181 — Goal agreement & sign-off (v0.18.1).
// Appended to schema.prisma by setup.sh (marker-guarded, idempotent). TWO new
// models mirroring public.goal_sheets / goal_amendments created by
// supabase/migrations/0010_add_goal_agreement_workflow.sql.
//
// Following the cross-module convention: cross-entity references to EXISTING
// tables (employees, appraisal_cycles, users) and to performance_goals are BARE
// columns here (FKs enforced in SQL only), so Employee / AppraisalCycle / User /
// PerformanceGoal are left UNTOUCHED — a goal is bound to its sheet by the
// natural key (cycleId + employeeId), not by a Prisma relation. The only real
// relation is GoalSheet <-> GoalAmendment (both new in this release).

model GoalSheet {
  id            String          @id @default(cuid())
  cycleId       String          @map("cycle_id")
  employeeId    String          @map("employee_id")
  managerId     String?         @map("manager_id")
  reviewState   String          @default("DRAFT") @map("review_state")
  submittedAt   DateTime?       @map("submitted_at")
  changesNote   String?         @map("changes_note")
  agreementNote String?         @map("agreement_note")
  approvedById  String?         @map("approved_by_id")
  approvedAt    DateTime?       @map("approved_at")
  managerSealIp String?         @map("manager_seal_ip")
  ackName       String?         @map("ack_name")
  ackAt         DateTime?       @map("ack_at")
  ackIp         String?         @map("ack_ip")
  sealed        Boolean         @default(false)
  amendments    GoalAmendment[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@unique([cycleId, employeeId])
  @@index([employeeId])
  @@index([managerId])
  @@index([reviewState])
  @@map("goal_sheets")
}

model GoalAmendment {
  id          String    @id @default(cuid())
  sheetId     String    @map("sheet_id")
  goalId      String?   @map("goal_id")
  kind        String    @default("NOTE")
  body        String
  newMeasure  String?   @map("new_measure")
  newTarget   String?   @map("new_target")
  createdById String?   @map("created_by_id")
  sheet       GoalSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([sheetId])
  @@index([goalId])
  @@map("goal_amendments")
}

// === TW-BONUS-MODELS-V0200 — Bonus model (WS6 Part 3). Pure-append; appended to
// prisma/schema.prisma by setup.sh when absent. Cross-entity references
// (employee, appraisal cycle) are BARE columns — no relations into existing
// models — so Employee / AppraisalCycle stay untouched (the goal_sheets pattern).
// Statuses are CHECK-constrained text (the v0.16.x pattern); the CHECK
// constraints live in supabase/migrations/0012_add_bonus_model.sql. ===
model BonusRound {
  id               String       @id @default(cuid())
  awardYear        Int          @unique @map("award_year")
  label            String
  status           String       @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED | LOCKED
  pbt              Decimal      @default(0) @db.Decimal(16, 2)
  poolRate         Decimal      @default(0.15) @map("pool_rate") @db.Decimal(6, 4)
  poolAmount       Decimal      @default(0) @map("pool_amount") @db.Decimal(16, 2)
  salaryBasis      String       @default("GROSS") @map("salary_basis") // BASIC | GROSS
  scalingFactor    Decimal      @default(1) @map("scaling_factor") @db.Decimal(8, 6)
  totalCalculated  Decimal?     @map("total_calculated") @db.Decimal(16, 2)
  totalAwarded     Decimal?     @map("total_awarded") @db.Decimal(16, 2)
  paymentMonth     Int          @default(4) @map("payment_month")
  paymentYear      Int          @map("payment_year")
  appraisalCycleId String?      @map("appraisal_cycle_id")
  confirmedNote    String?      @map("confirmed_note")
  approvedById     String?      @map("approved_by_id")
  approvedAt       DateTime?    @map("approved_at")
  lockedAt         DateTime?    @map("locked_at")
  awards           BonusAward[]
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@map("bonus_rounds")
}

model BonusAward {
  id              String         @id @default(cuid())
  bonusRoundId    String         @map("bonus_round_id")
  employeeId      String         @map("employee_id")
  eeId            String         @map("ee_id")
  employeeName    String         @map("employee_name")
  grade           String
  targetMonths    Decimal        @map("target_months") @db.Decimal(6, 4)
  monthlySalary   Decimal        @map("monthly_salary") @db.Decimal(14, 2)
  targetBonus     Decimal        @map("target_bonus") @db.Decimal(14, 2)
  multiplier      Decimal        @default(1.0) @db.Decimal(5, 3)
  integrityGate   Boolean        @default(false) @map("integrity_gate")
  appraisalRating String?        @map("appraisal_rating")
  calculatedBonus Decimal        @default(0) @map("calculated_bonus") @db.Decimal(14, 2)
  awardedBonus    Decimal        @default(0) @map("awarded_bonus") @db.Decimal(14, 2)
  deferred        Boolean        @default(false)
  immediateAmount Decimal        @default(0) @map("immediate_amount") @db.Decimal(14, 2)
  deferredAmount  Decimal        @default(0) @map("deferred_amount") @db.Decimal(14, 2)
  reviewStatus    String         @default("PENDING") @map("review_status") // PENDING | CONFIRMED
  note            String?
  confirmedById   String?        @map("confirmed_by_id")
  confirmedAt     DateTime?      @map("confirmed_at")
  bonusRound      BonusRound     @relation(fields: [bonusRoundId], references: [id], onDelete: Cascade)
  tranches        BonusTranche[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@unique([bonusRoundId, employeeId])
  @@index([bonusRoundId])
  @@index([employeeId])
  @@map("bonus_awards")
}

model BonusTranche {
  id             String     @id @default(cuid())
  bonusAwardId   String     @map("bonus_award_id")
  bonusRoundId   String     @map("bonus_round_id")
  employeeId     String     @map("employee_id")
  sequence       Int
  label          String
  amount         Decimal    @db.Decimal(14, 2)
  scheduledMonth Int        @default(4) @map("scheduled_month")
  scheduledYear  Int        @map("scheduled_year")
  status         String     @default("SCHEDULED") // SCHEDULED | PAID | CLAWED_BACK | FORFEITED
  paidAt         DateTime?  @map("paid_at")
  note           String?
  bonusAward     BonusAward @relation(fields: [bonusAwardId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  @@index([bonusAwardId])
  @@index([bonusRoundId])
  @@index([employeeId])
  @@map("bonus_tranches")
}

model BonusTrancheEvent {
  id             String   @id @default(cuid())
  bonusTrancheId String   @map("bonus_tranche_id")
  bonusAwardId   String   @map("bonus_award_id")
  bonusRoundId   String   @map("bonus_round_id")
  employeeId     String   @map("employee_id")
  eventType      String   @map("event_type") // PAID | CLAWBACK | FORFEIT | REINSTATE
  amount         Decimal  @db.Decimal(14, 2)
  boardOverride  Boolean  @default(false) @map("board_override")
  reason         String?
  actorId        String?  @map("actor_id")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([bonusTrancheId])
  @@index([bonusRoundId])
  @@index([employeeId])
  @@index([eventType])
  @@map("bonus_tranche_events")
}

// schema-append/raise-models.prisma (v0.22.0) — REFERENCE COPY.
// setup.sh appends this block to prisma/schema.prisma (marker-guarded on
// "model RaiseCycle", idempotent), then runs `prisma generate`. It mirrors the
// public.raise_cycles / public.raise_items tables created by
// supabase/migrations/0014_add_raise_mechanism.sql.
//
// Cross-module convention (see bonus / compensation): cross-entity references to
// EXISTING tables (employees, users, compensation_profiles) are BARE columns here —
// their FKs are enforced in SQL only — so Employee / User / CompensationProfile stay
// untouched. The only real Prisma relation is RaiseCycle <-> RaiseItem (both new).
// Ids are app-generated cuid; status / bandFlag are plain Strings (CHECK-constrained
// in the migration; no new Postgres enums).

// TW-RAISE-MODELS-V0220
model RaiseCycle {
  id                  String      @id @default(cuid())
  label               String
  status              String      @default("DRAFT")
  milestoneLabel      String      @map("milestone_label")
  revenueTarget       Decimal     @map("revenue_target") @db.Decimal(16, 2)
  raisePercent        Decimal     @map("raise_percent") @db.Decimal(6, 4)
  revenueObserved     Decimal?    @map("revenue_observed") @db.Decimal(16, 2)
  revenueConfirmed    Decimal?    @map("revenue_confirmed") @db.Decimal(16, 2)
  effectiveDate       DateTime    @map("effective_date")
  confirmedNote       String?     @map("confirmed_note")
  confirmedById       String?     @map("confirmed_by_id")
  preparedById        String?     @map("prepared_by_id")
  submittedById       String?     @map("submitted_by_id")
  submittedAt         DateTime?   @map("submitted_at")
  reviewedById        String?     @map("reviewed_by_id")
  reviewedAt          DateTime?   @map("reviewed_at")
  approvedById        String?     @map("approved_by_id")
  approvedAt          DateTime?   @map("approved_at")
  appliedAt           DateTime?   @map("applied_at")
  lockedAt            DateTime?   @map("locked_at")
  totalEmployees      Int?        @map("total_employees")
  totalAnnualIncrease Decimal?    @map("total_annual_increase") @db.Decimal(16, 2)
  totalNewAnnual      Decimal?    @map("total_new_annual") @db.Decimal(16, 2)
  items               RaiseItem[]
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("raise_cycles")
}

model RaiseItem {
  id               String     @id @default(cuid())
  raiseCycleId     String     @map("raise_cycle_id")
  raiseCycle       RaiseCycle @relation(fields: [raiseCycleId], references: [id], onDelete: Cascade)
  employeeId       String     @map("employee_id")
  eeId             String     @map("ee_id")
  employeeName     String     @map("employee_name")
  grade            String?
  oldBasic         Decimal    @map("old_basic") @db.Decimal(14, 2)
  oldUtility       Decimal    @map("old_utility") @db.Decimal(14, 2)
  oldQuarterly     Decimal    @map("old_quarterly") @db.Decimal(14, 2)
  oldAnnualTotal   Decimal    @map("old_annual_total") @db.Decimal(16, 2)
  newBasic         Decimal    @map("new_basic") @db.Decimal(14, 2)
  newUtility       Decimal    @map("new_utility") @db.Decimal(14, 2)
  newQuarterly     Decimal    @map("new_quarterly") @db.Decimal(14, 2)
  newAnnualTotal   Decimal    @map("new_annual_total") @db.Decimal(16, 2)
  annualIncrease   Decimal    @map("annual_increase") @db.Decimal(16, 2)
  bandMin          Decimal?   @map("band_min") @db.Decimal(14, 2)
  bandMid          Decimal?   @map("band_mid") @db.Decimal(14, 2)
  bandMax          Decimal?   @map("band_max") @db.Decimal(14, 2)
  bandFlag         String     @default("WITHIN") @map("band_flag")
  included         Boolean    @default(true)
  excludeReason    String?    @map("exclude_reason")
  capApplied       Boolean    @default(false) @map("cap_applied")
  appliedProfileId String?    @map("applied_profile_id")
  note             String?
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@unique([raiseCycleId, employeeId])
  @@index([raiseCycleId])
  @@index([employeeId])
  @@map("raise_items")
}


// TW-QUALIFICATION-SPONSORSHIP-MODELS-V0240 — Qualification sponsorship (WS6 Part 4, v0.24.0).
// Appended to schema.prisma by setup.sh (marker-guarded, idempotent). THREE new models
// mirroring public.qualification_sponsorships / sponsorship_costs / sponsorship_attempts
// created by supabase/migrations/0015_add_qualification_sponsorship.sql.
//
// Following the cross-module convention (see raise / scorecards / performance): cross-entity
// references to EXISTING tables (employees, learning_modules, staff_documents, users) are BARE
// columns here (their FKs are enforced in SQL only), so Employee / LearningModule / StaffDocument
// / User are left untouched. The only real Prisma relations are the new-to-new parent/child
// QualificationSponsorship <-> SponsorshipCost / SponsorshipAttempt. Ids are app-generated cuid;
// status vocabularies are plain Strings (CHECK-constrained in the migration).

model QualificationSponsorship {
  id                  String               @id @default(cuid())
  employeeId          String               @map("employee_id")
  eeId                String               @map("ee_id")
  employeeName        String               @map("employee_name")
  qualificationName   String               @map("qualification_name")
  awardingBody        String?              @map("awarding_body")
  learningModuleId    String?              @map("learning_module_id")
  agreementDocumentId String?              @map("agreement_document_id")
  status              String               @default("PROPOSED")
  bondingMonths       Int?                 @map("bonding_months")
  bondingStartBasis   String               @default("ON_COMPLETION") @map("bonding_start_basis")
  bondingWaived       Boolean              @default(false) @map("bonding_waived")
  repaymentStatus     String               @default("NOT_APPLICABLE") @map("repayment_status")
  repaymentAmount     Decimal?             @map("repayment_amount") @db.Decimal(16, 2)
  agreementDate       DateTime?            @map("agreement_date")
  proposedById        String?              @map("proposed_by_id")
  approvedById        String?              @map("approved_by_id")
  withdrawnById       String?              @map("withdrawn_by_id")
  proposedAt          DateTime?            @map("proposed_at")
  approvedAt          DateTime?            @map("approved_at")
  startedAt           DateTime?            @map("started_at")
  completedAt         DateTime?            @map("completed_at")
  withdrawnAt         DateTime?            @map("withdrawn_at")
  note                String?
  costs               SponsorshipCost[]
  attempts            SponsorshipAttempt[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([employeeId])
  @@index([status])
  @@index([learningModuleId])
  @@map("qualification_sponsorships")
}

model SponsorshipCost {
  id            String                   @id @default(cuid())
  sponsorshipId String                   @map("sponsorship_id")
  sponsorship   QualificationSponsorship @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  costType      String                   @map("cost_type")
  description   String?
  amount        Decimal                  @db.Decimal(14, 2)
  incurredDate  DateTime?                @map("incurred_date")
  paid          Boolean                  @default(false)
  paidDate      DateTime?                @map("paid_date")
  waived        Boolean                  @default(false)
  note          String?
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  @@index([sponsorshipId])
  @@index([costType])
  @@map("sponsorship_costs")
}

model SponsorshipAttempt {
  id            String                   @id @default(cuid())
  sponsorshipId String                   @map("sponsorship_id")
  sponsorship   QualificationSponsorship @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  levelLabel    String                   @map("level_label")
  attemptNumber Int?                     @map("attempt_number")
  sittingDate   DateTime?                @map("sitting_date")
  outcome       String                   @default("SCHEDULED")
  score         String?
  note          String?
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")

  @@index([sponsorshipId])
  @@index([outcome])
  @@map("sponsorship_attempts")
}
